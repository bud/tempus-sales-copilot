# Tempus Sales Copilot — API key configuration
# Copy this file to .env and fill in your key(s).
# The app works in demo mode without any key.

# Option A: OpenAI (uses gpt-4o-mini)
OPENAI_API_KEY=sk-...

# Option B: Anthropic (uses claude-haiku-4-5)
# Takes precedence over OpenAI if both are set.
ANTHROPIC_API_KEY=sk-ant-...
